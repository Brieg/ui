{
  "name": "@ui/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx serve ui",
    "build": "nx build ui",
    "test": "nx test ui",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit -p apps/ui/tsconfig.json",
    "test:coverage": "nx test ui --coverage",
    "verify": "npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "prepare": "husky"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{json,md,html,scss,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/forms": "~21.2.0",
    "@angular/platform-browser": "~21.2.0",
    "@angular/platform-browser-dynamic": "~21.2.0",
    "@angular/router": "~21.2.0",
    "rxjs": "~7.8.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~21.2.0",
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/language-service": "~21.2.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "23.0.1",
    "@nx/angular-rspack": "23.0.1",
    "@nx/devkit": "23.0.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/jest": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/playwright": "23.0.1",
    "@nx/rspack": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@playwright/test": "^1.37.0",
    "@rspack/cli": "1.6.8",
    "@rspack/core": "1.6.8",
    "@rspack/dev-server": "^1.1.4",
    "@schematics/angular": "~21.2.0",
    "@swc/helpers": "~0.5.18",
    "@types/jest": "~30.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/utils": "^8.40.0",
    "angular-eslint": "^21.2.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jest": "~30.3.0",
    "jest-environment-jsdom": "~30.3.0",
    "jest-preset-angular": "~16.0.0",
    "jest-util": "~30.3.0",
    "lint-staged": "^17.0.8",
    "nx": "23.0.1",
    "prettier": "~3.6.2",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "webpack-merge": "^5.8.0"
  }
